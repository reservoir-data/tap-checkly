{
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "The unique ID of this result."
    },
    "name": {
      "type": [
        "string",
        "null"
      ],
      "description": "The name of the check."
    },
    "checkId": {
      "type": [
        "string",
        "null"
      ],
      "description": "The ID of the check."
    },
    "hasFailures": {
      "type": [
        "boolean",
        "null"
      ],
      "description": "Describes if any failure has occurred during this check run. This is should be your mainmain focus for assessing API or browser check behaviour. Assertions that fail, timeouts or failing scripts all resolve tothis value being true."
    },
    "hasErrors": {
      "type": [
        "boolean",
        "null"
      ],
      "description": "Describes if an internal error has occured in Checkly's backend. This should be false in almost all cases."
    },
    "isDegraded": {
      "type": [
        "boolean",
        "null"
      ],
      "description": "A check is degraded if it is over the degradation limit set by the \"degradedResponseTime\" field on the check. Applies only to API checks."
    },
    "overMaxResponseTime": {
      "type": [
        "boolean",
        "null"
      ],
      "description": "Set to true if the response time is over the limit set by the \"maxResponseTime\" field on the check. Applies only to API checks."
    },
    "runLocation": {
      "type": [
        "string",
        "null"
      ],
      "description": "What data center location this check result originated from."
    },
    "startedAt": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "stoppedAt": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "created_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "responseTime": {
      "type": [
        "number",
        "null"
      ],
      "description": "Describes the time it took to execute relevant parts of this check. Any setup timeor system time needed to start executing this check in the Checkly backend is not part of this."
    },
    "apiCheckResult": {
      "type": [
        "object",
        "null"
      ],
      "description": "The response data for an API check.",
      "properties": {
        "assertions": {
          "type": [
            "array",
            "null"
          ],
          "description": "List of API check assertions.",
          "example": [
            {
              "source": "STATUS_CODE",
              "target": 200
            }
          ],
          "items": {
            "type": "string"
          }
        },
        "request": {
          "type": [
            "object",
            "null"
          ],
          "description": "The request for the API.",
          "properties": {
            "method": {
              "type": [
                "string",
                "null"
              ],
              "example": "GET"
            },
            "url": {
              "type": [
                "string",
                "null"
              ],
              "example": "https://api.checklyhq.com"
            },
            "data": {
              "type": [
                "string",
                "null"
              ],
              "example": ""
            },
            "headers": {
              "type": [
                "object",
                "null"
              ]
            },
            "params": {
              "type": [
                "object",
                "null"
              ]
            }
          }
        },
        "response": {
          "type": [
            "object",
            "null"
          ],
          "description": "The API response.",
          "properties": {
            "status": {
              "type": [
                "number",
                "null"
              ],
              "example": 200
            },
            "statusText": {
              "type": [
                "string",
                "null"
              ],
              "example": "OK"
            },
            "body": {
              "type": [
                "string",
                "null"
              ],
              "example": "<title> Checkly Public API </title>"
            },
            "headers": {
              "type": [
                "object",
                "null"
              ]
            },
            "timings": {
              "type": [
                "object",
                "null"
              ]
            },
            "timingPhases": {
              "type": [
                "object",
                "null"
              ]
            }
          }
        },
        "requestError": {
          "type": [
            "string",
            "null"
          ],
          "description": "Describes if an error occurred on the request.",
          "example": "null"
        },
        "jobLog": {
          "type": [
            "object",
            "null"
          ],
          "description": "Check run log results."
        },
        "jobAssets": {
          "type": [
            "array",
            "null"
          ],
          "description": "Assets generated from the check run.",
          "example": "null",
          "items": {
            "type": "string"
          }
        },
        "pcapDataUrl": {
          "type": [
            "string",
            "null"
          ],
          "description": "Packet capture data if available as redirect/download URL."
        }
      }
    },
    "browserCheckResult": {
      "type": [
        "object",
        "null"
      ],
      "description": "The response data for a browser check.",
      "example": "null",
      "properties": {
        "type": {
          "type": [
            "string",
            "null"
          ],
          "description": "The type of framework the check is using.",
          "example": "PLAYWRIGHT"
        },
        "traceSummary": {
          "type": [
            "object",
            "null"
          ],
          "description": "The summary of errors in the check run."
        },
        "pages": {
          "type": [
            "array",
            "null"
          ],
          "description": "List of pages used on the check run.",
          "example": [
            {
              "url": "https://www.checklyhq.com/",
              "webVitals": {
                "CLS": {
                  "score": "GOOD",
                  "value": 0.000146484375
                }
              }
            }
          ],
          "items": {
            "type": "string"
          }
        },
        "playwrightTestVideos": {
          "type": [
            "array",
            "null"
          ],
          "description": "List of Playwright Test videos.",
          "example": [
            "https://api.checklyhq.com/v1/assets/checkRunData/eu-central-1/00000000-0000-0000-0000-0000000000/00000000-0000-0000-0000-0000000000/1675691025832/visit-page-and-take-screenshot-1675691043856.webm"
          ],
          "items": {
            "type": "string"
          }
        },
        "errors": {
          "type": [
            "array",
            "null"
          ],
          "description": "List of errors on the check run.",
          "example": [],
          "items": {
            "type": "string"
          }
        },
        "endTime": {
          "type": [
            "number",
            "null"
          ],
          "description": "End time of the check run.",
          "example": 1648573423995
        },
        "startTime": {
          "type": [
            "number",
            "null"
          ],
          "description": "Start time of the check run.",
          "example": 1648573423994
        },
        "runtimeVersion": {
          "type": [
            "string",
            "null"
          ],
          "description": "Active runtime version.",
          "example": "2023.09"
        },
        "jobLog": {
          "type": [
            "array",
            "null"
          ],
          "description": "Check run log results.",
          "example": {
            "time": 1648573423995,
            "msg": "Starting job",
            "level": "DEBUG"
          },
          "items": {
            "type": "string"
          }
        },
        "jobAssets": {
          "type": [
            "array",
            "null"
          ],
          "description": "Assets generated from the check run.",
          "example": "null",
          "items": {
            "type": "string"
          }
        },
        "playwrightTestTraces": {
          "type": [
            "array",
            "null"
          ],
          "description": "List of Playwright Test traces.",
          "example": [
            "https://api.checklyhq.com/v1/assets/checkRunData/eu-central-1/00000000-0000-0000-0000-0000000000/00000000-0000-0000-0000-0000000000/1675691025832/visit-page-and-take-screenshot.zip"
          ],
          "items": {
            "type": "string"
          }
        },
        "playwrightTestJsonReportFile": {
          "type": [
            "string",
            "null"
          ],
          "description": "Playwright Test JSON report.",
          "example": "https://api.checklyhq.com/v1/assets/checkRunData/eu-central-1/00000000-0000-0000-0000-0000000000/00000000-0000-0000-0000-0000000000/1675691025832/report.json"
        }
      }
    },
    "multiStepCheckResult": {
      "type": [
        "object",
        "null"
      ],
      "description": "The response data for a multi-step check.",
      "example": "null",
      "properties": {
        "errors": {
          "type": [
            "array",
            "null"
          ],
          "description": "List of errors on the check run.",
          "example": [],
          "items": {
            "type": "string"
          }
        },
        "endTime": {
          "type": [
            "number",
            "null"
          ],
          "description": "End time of the check run.",
          "example": 1648573423995
        },
        "startTime": {
          "type": [
            "number",
            "null"
          ],
          "description": "Start time of the check run.",
          "example": 1648573423994
        },
        "runtimeVersion": {
          "type": [
            "string",
            "null"
          ],
          "description": "Active runtime version.",
          "example": "2023.09"
        },
        "jobLog": {
          "type": [
            "array",
            "null"
          ],
          "description": "Check run log results.",
          "example": {
            "time": 1648573423995,
            "msg": "Starting job",
            "level": "DEBUG"
          },
          "items": {
            "type": "string"
          }
        },
        "jobAssets": {
          "type": [
            "array",
            "null"
          ],
          "description": "Assets generated from the check run.",
          "example": "null",
          "items": {
            "type": "string"
          }
        },
        "playwrightTestTraces": {
          "type": [
            "array",
            "null"
          ],
          "description": "List of Playwright Test traces.",
          "example": [
            "https://api.checklyhq.com/v1/assets/checkRunData/eu-central-1/00000000-0000-0000-0000-0000000000/00000000-0000-0000-0000-0000000000/1675691025832/visit-page-and-take-screenshot.zip"
          ],
          "items": {
            "type": "string"
          }
        },
        "playwrightTestJsonReportFile": {
          "type": [
            "string",
            "null"
          ],
          "description": "Playwright Test JSON report.",
          "example": "https://api.checklyhq.com/v1/assets/checkRunData/eu-central-1/00000000-0000-0000-0000-0000000000/00000000-0000-0000-0000-0000000000/1675691025832/report.json"
        }
      }
    },
    "agenticCheckResult": {
      "type": [
        "object",
        "null"
      ],
      "description": "The response data for an agentic check.",
      "properties": {
        "summary": {
          "type": [
            "string",
            "null"
          ],
          "description": "Human-readable recap of the agent run written by the agent itself.",
          "example": "The homepage loaded correctly and all assertions passed."
        },
        "prompt": {
          "type": [
            "string",
            "null"
          ],
          "description": "The prompt that was executed for this run."
        },
        "assertions": {
          "type": [
            "array",
            "null"
          ],
          "description": "List of assertions the agent evaluated during the run.",
          "items": {
            "type": [
              "object",
              "null"
            ],
            "properties": {
              "condition": {
                "type": [
                  "string",
                  "null"
                ],
                "description": "Human-readable condition the agent evaluated.",
                "example": "The homepage returns an HTTP 200 status"
              },
              "passed": {
                "type": [
                  "boolean",
                  "null"
                ],
                "description": "Whether the assertion passed.",
                "example": true
              },
              "actual": {
                "type": [
                  "string",
                  "null"
                ],
                "description": "What the agent actually observed.",
                "example": "200"
              },
              "expected": {
                "type": [
                  "string",
                  "null"
                ],
                "description": "What the assertion required.",
                "example": "200"
              }
            }
          }
        },
        "suggestions": {
          "type": [
            "array",
            "null"
          ],
          "description": "Suggestions the agent produced for extending the check.",
          "items": {
            "type": [
              "object",
              "null"
            ],
            "properties": {
              "summary": {
                "type": [
                  "string",
                  "null"
                ],
                "description": "Human-readable summary of the agent's suggestion.",
                "example": "Monitor the checkout flow end-to-end"
              },
              "prompt": {
                "type": [
                  "string",
                  "null"
                ],
                "description": "Prompt fragment the user can append to extend the check.",
                "example": "Sign in and verify the checkout page loads"
              },
              "secrets": {
                "type": [
                  "array",
                  "null"
                ],
                "description": "Environment variable names the suggestion would require.",
                "example": [
                  "TEST_USER_EMAIL",
                  "TEST_USER_PASSWORD"
                ],
                "items": {
                  "type": "string"
                }
              },
              "category": {
                "type": [
                  "string",
                  "null"
                ],
                "description": "Category of the suggestion.",
                "example": "credentials"
              }
            }
          }
        },
        "steps": {
          "type": [
            "array",
            "null"
          ],
          "description": "Sequence of tool calls and messages emitted by the agent.",
          "items": {
            "type": [
              "object",
              "null"
            ],
            "properties": {
              "type": {
                "type": [
                  "string",
                  "null"
                ],
                "description": "Kind of step emitted by the agent.",
                "example": "tool_call"
              },
              "name": {
                "type": [
                  "string",
                  "null"
                ],
                "description": "Name of the tool invoked (for tool_call / tool_result steps).",
                "example": "http_request"
              },
              "input": {
                "type": [
                  "object",
                  "null"
                ],
                "description": "Input passed to the tool, when applicable."
              },
              "output": {
                "type": [
                  "string",
                  "null"
                ],
                "description": "Output text or message body."
              },
              "timestamp": {
                "type": [
                  "string",
                  "null"
                ],
                "description": "ISO timestamp when the step was emitted.",
                "example": "2026-04-06T14:15:22.000Z"
              },
              "sequenceNumber": {
                "type": [
                  "integer",
                  "null"
                ],
                "description": "Monotonic sequence number within a run.",
                "example": 3
              }
            }
          }
        },
        "errors": {
          "type": [
            "array",
            "null"
          ],
          "description": "Errors recorded during the run, if any.",
          "items": {
            "type": [
              "object",
              "null"
            ]
          }
        },
        "artifactManifest": {
          "type": [
            "object",
            "null"
          ],
          "description": "Map of artifact file paths to human-readable descriptions."
        }
      }
    },
    "checkRunId": {
      "type": [
        "number",
        "null"
      ],
      "description": "The id of the specific check run that created this check result."
    },
    "attempts": {
      "type": [
        "number",
        "null"
      ],
      "description": "How often this check was retried. This will be larger than 0 when double checking is enabled."
    },
    "resultType": {
      "type": [
        "string",
        "null"
      ],
      "description": "The type of result. FINAL means this is the final result of the check run. ATTEMPT means this is a result of a double check attempt.",
      "example": "FINAL",
      "default": "FINAL"
    },
    "sequenceId": {
      "type": [
        "string",
        "null"
      ],
      "description": "The sequence ID of the check run. This is used to group check runs with multiple attempts together.",
      "example": "2dbfa2a3-5477-45ea-ac33-ee55b8ea66ff",
      "x-format": {
        "guid": true
      }
    },
    "errorGroupIds": {
      "type": [
        "array",
        "null"
      ],
      "description": "IDs of the error groups associated with this check result. Always an array: empty when the result has no associated error groups, single-element when there is one (typical for API/URL/TCP/ICMP checks), or multi-element for Playwright and multistep checks that can produce multiple distinct errors per run. Use these IDs to fetch the corresponding error group via the error-groups endpoint.",
      "example": [
        "883af87b-ac7c-44e3-9376-b4bece04e788"
      ],
      "items": {
        "type": "string",
        "x-format": {
          "guid": true
        }
      }
    }
  },
  "required": [
    "resultType"
  ]
}
