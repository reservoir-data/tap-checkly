            {
              "source": "STATUS_CODE",
              "target": 200
            }
          ],
          "items": {
            "type": "string"
          }
        },
        "request": {
          "type": [
            "object",
            "null"
          ],
          "description": "The request for the API.",
          "properties": {
            "method": {
              "type": [
                "string",
                "null"
              ],
              "example": "GET"
            },
            "url": {
              "type": [
                "string",
                "null"
              ],
              "example": "https://api.checklyhq.com"
            },
            "data": {
              "type": [
                "string",
                "null"
              ],
              "example": ""
            },
            "headers": {
              "type": [
                "object",
                "null"
              ]
            },
            "params": {
              "type": [
                "object",
                "null"
              ]
