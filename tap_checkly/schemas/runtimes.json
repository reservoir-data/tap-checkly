{
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "The unique name of this runtime.",
      "example": "2026.04"
    },
    "multiStepSupport": {
      "type": [
        "boolean",
        "null"
      ],
      "description": "Does this runtime supports multi step checks"
    },
    "nodeJsVersion": {
      "type": [
        "string",
        "null"
      ],
      "description": "The full Node.js version available in this runtime.",
      "example": "v18.20.3"
    },
    "stage": {
      "type": [
        "string",
        "null"
      ],
      "description": "Current life stage of a runtime.",
      "example": "STABLE"
    },
    "runtimeEndOfLife": {
      "type": [
        "string",
        "null"
      ],
      "description": "Date which a runtime will be removed from our platform.",
      "example": "12/31/2022"
    },
    "description": {
      "type": [
        "string",
        "null"
      ],
      "description": "A short, human readable description of the main updates in this runtime.",
      "example": "Main updates are Playwright 1.58.2"
    },
    "dependencies": {
      "type": [
        "object",
        "null"
      ],
      "description": "An object with all dependency package names and versions as in a standard package.json.",
      "example": {
        "@playwright/test": "1.58.2",
        "@axe-core/playwright": "4.11.1",
        "@azure/identity": "4.13.0",
        "@azure/keyvault-secrets": "4.10.0",
        "@checkly/playwright-helpers": "1.0.4",
        "@clerk/testing": "1.14.2",
        "@faker-js/faker": "10.3.0",
        "@google-cloud/local-auth": "3.0.1",
        "@kubernetes/client-node": "1.4.0",
        "@opentelemetry/api": "1.9.0",
        "@opentelemetry/exporter-metrics-otlp-grpc": "0.212.0",
        "@opentelemetry/sdk-metrics": "2.5.1",
        "@opentelemetry/sdk-trace-base": "2.5.1",
        "@t3-oss/env-nextjs": "0.7.3",
        "@xmldom/xmldom": "0.9.8",
        "aws4": "1.13.2",
        "axios": "1.13.5",
        "axios-cookiejar-support": "5.0.5",
        "crypto-js": "4.2.0",
        "csv-parse": "6.1.0",
        "date-fns": "4.1.0",
        "date-fns-tz": "3.2.0",
        "dotenv": "17.3.1",
        "ethers": "6.16.0",
        "expect": "30.2.0",
        "form-data": "4.0.5",
        "gaxios": "7.1.3",
        "gmail-api-parse-message-ts": "2.2.33",
        "google-auth-library": "10.6.1",
        "googleapis": "171.4.0",
        "graphql": "16.13.0",
        "graphql-tag": "2.12.6",
        "http": "24.13.1",
        "https": "24.13.1",
        "imapflow": "1.2.10",
        "jose": "6.1.3",
        "jsonwebtoken": "9.0.3",
        "lodash": "4.17.23",
        "long": "5.3.2",
        "mailosaur": "11.0.2",
        "moment": "2.30.1",
        "mysql": "2.18.1",
        "mysql2": "3.18.2",
        "nice-grpc": "2.1.14",
