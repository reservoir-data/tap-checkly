            },
            "statusText": {
              "type": [
                "string",
                "null"
              ],
              "example": "OK"
            },
            "body": {
              "type": [
                "string",
                "null"
              ],
              "example": "<title> Checkly Public API </title>"
            },
            "headers": {
              "type": [
                "object",
                "null"
              ]
            },
            "timings": {
              "type": [
                "object",
                "null"
              ]
            },
            "timingPhases": {
              "type": [
                "object",
                "null"
              ]
            }
          }
        },
        "requestError": {
          "type": [
            "string",
            "null"
          ],
          "description": "Describes if an error occurred on the request.",
          "example": null
